---
// src/components/AdBanner.astro
export interface Props {
  type: 'house' | 'adsense';
  ad?: {
    title?: string;
    image?: any;   // Sanity image reference
    linkUrl?: string;
  } | null;
  label?: string;
  class?: string;
}

import { urlFor } from '../lib/sanity';

const {
  type,
  ad = null,
  label = 'Advertisement',
  class: extraClass = '',
} = Astro.props;

const imgSrc = ad?.image ? urlFor(ad.image).width(900).height(200).auto('format').url() : null;
---

{type === 'house' && ad?.linkUrl ? (
  <!-- House Ad with real data -->
  <a href={ad.linkUrl} target="_blank" rel="noopener noreferrer" class={`block w-full rounded-2xl overflow-hidden group ${extraClass}`}>
    <div class="relative h-32 md:h-40 bg-honey/10">
      {imgSrc ? (
        <img src={imgSrc} alt={ad.title ?? 'House advertisement'} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
      ) : (
        <div class="flex flex-col items-center justify-center h-full text-honey">
          <svg class="w-12 h-12 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="14" rx="2" stroke-width="1.5"/><path d="M3 14l4-4 4 4 4-6 4 4" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="text-sm font-semibold text-bark">{ad.title ?? 'House Ad'}</span>
        </div>
      )}
    </div>
  </a>
) : (
  <!-- Styled ADVERTISEMENT placeholder -->
  <div class={`ad-placeholder w-full ${extraClass}`}>
    <span class="ad-label">{label}</span>
    {type === 'house' ? (
      <div class="mt-3 w-full h-24 bg-honey/10 rounded-xl flex items-center justify-center gap-3">
        <svg class="w-8 h-8 text-honey/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="14" rx="2" stroke-width="1.5"/><path d="M3 14l4-4 4 4 4-6 4 4" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span class="text-sm text-muted font-medium">House Ad Banner (728 × 90)</span>
      </div>
    ) : (
      <div class="mt-3 w-full max-w-xs mx-auto h-36 bg-honey/10 rounded-xl flex flex-col items-center justify-center gap-2">
        <svg class="w-8 h-8 text-honey/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/><path d="M9 9h6M9 12h6M9 15h4" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span class="text-xs text-muted font-medium">Google AdSense (300 × 250)</span>
      </div>
    )}
  </div>
)}
