---
// src/components/PostCard.astro
import { urlFor } from '../lib/sanity';

export interface Props {
  post: {
    _id: string;
    title: string;
    slug: { current: string };
    mainImage?: any;
    tags?: string[];
    body?: any[];
  };
}

const { post } = Astro.props;

const imgSrc = post.mainImage
  ? urlFor(post.mainImage).width(600).height(400).auto('format').url()
  : null;

// Extract first paragraph text as excerpt
const excerpt = post.body
  ?.find((b: any) => b._type === 'block' && b.style === 'normal')
  ?.children
  ?.map((c: any) => c.text)
  .join('') ?? '';
---

<a
  href={`/blog/${post.slug.current}`}
  class="group card flex flex-col overflow-hidden"
  aria-label={post.title}
>
  <!-- Image -->
  <div class="relative overflow-hidden aspect-[3/2] bg-blush/20">
    {imgSrc ? (
      <img
        src={imgSrc}
        alt={post.title}
        loading="lazy"
        transition:name={`blog-image-${post.slug.current}`}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-blush/60">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
      </div>
    )}

    <!-- Category badge -->
    {post.tags?.[0] && (
      <span class="absolute top-3 left-3 bg-blush text-bark text-xs font-bold px-3 py-1 rounded-full shadow-sm">
        {post.tags[0]}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-4 flex-1 flex flex-col">
    <h3 class="font-serif text-lg font-semibold text-bark leading-snug mb-2 group-hover:text-honey transition-colors duration-200 text-balance">
      {post.title}
    </h3>
    {excerpt && (
      <p class="text-sm text-muted leading-relaxed line-clamp-2 mb-3">
        {excerpt}
      </p>
    )}
    <span class="mt-auto text-xs font-semibold text-honey group-hover:underline">
      Read More →
    </span>
  </div>
</a>
