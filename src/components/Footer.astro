---
// src/components/Footer.astro
const year = new Date().getFullYear();

const footerLinks = [
  { label: 'Home',       href: '/'           },
  { label: 'Recipes',    href: '/recipes'    },
  { label: 'Blog',       href: '/blog'       },
  { label: 'Podcast',    href: '/podcast'    },
  { label: 'Community',  href: '/community'  },
  { label: 'Newsletter', href: '/newsletter' },
  { label: 'Cookbook',   href: '/cookbook'   },
];

const socialLinks = [
  { label: 'Instagram', href: '#', icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>` },
  { label: 'Pinterest', href: '#', icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>` },
  { label: 'Facebook',  href: '#', icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>` },
  { label: 'YouTube',   href: '#', icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>` },
];
---

<footer class="bg-bark text-cream mt-16">
  <!-- Newsletter strip -->
  <div class="bg-honey">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h2 class="font-serif text-2xl text-bark font-bold">Get recipes in your inbox 🍯</h2>
        <p class="text-bark/70 text-sm mt-1">New recipes every week, plus exclusive tips and freebies.</p>
      </div>
      <form class="flex w-full md:w-auto gap-2" onsubmit="return false;">
        <input
          id="footer-newsletter-email"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="your@email.com"
          aria-label="Email address for newsletter"
          class="flex-1 md:w-64 px-4 py-2.5 rounded-full text-bark placeholder:text-bark/50 text-sm
                 bg-white/80 focus:outline-none focus:ring-2 focus:ring-bark border-0"
        />
        <button type="submit" class="bg-bark text-cream font-semibold px-6 py-2.5 rounded-full text-sm hover:bg-gray-800 transition-colors">
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Main footer content -->
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg class="w-8 h-8 text-honey" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
            <path d="M16 2C10.5 2 6 6.5 6 12c0 3.5 1.7 6.6 4.3 8.6L16 30l5.7-9.4C24.3 18.6 26 15.5 26 12c0-5.5-4.5-10-10-10z"/>
          </svg>
          <span class="font-serif text-xl font-bold text-cream">JM Recipes<span class="text-honey">Web</span></span>
        </a>
        <p class="text-cream/60 text-sm leading-relaxed max-w-xs">
          Simple, plant-forward recipes with 10 ingredients or less, 1 bowl, or 30 minutes.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-serif text-lg text-honey mb-4">Explore</h3>
        <ul class="space-y-2">
          {footerLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-cream/60 text-sm hover:text-honey transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social + legal -->
      <div>
        <h3 class="font-serif text-lg text-honey mb-4">Follow Along</h3>
        <div class="flex gap-3 mb-6">
          {socialLinks.map(({ label, href, icon }) => (
            <a
              href={href}
              aria-label={label}
              class="w-9 h-9 rounded-full bg-cream/10 flex items-center justify-center text-cream/70 hover:bg-honey hover:text-bark transition-all duration-200"
              set:html={icon}
            />
          ))}
        </div>

        <div class="text-cream/40 text-xs space-y-1">
          <p>&copy; {year} JM Recipes Web. All rights reserved.</p>
          <div class="flex gap-3">
            <a href="#" class="hover:text-honey transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-honey transition-colors">Terms of Use</a>
            <a href="#" class="hover:text-honey transition-colors">Disclosure</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</footer>
