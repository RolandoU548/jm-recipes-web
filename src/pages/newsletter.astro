---
// src/pages/newsletter.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  '🥑 New recipes every week, delivered to your inbox',
  '🎁 Free meal plans and grocery list templates',
  '🌱 Exclusive tips for healthy, simple cooking',
  '💌 Early access to new cookbooks and resources',
  '🚫 No spam, ever. Unsubscribe anytime.',
];
---

<Layout title="Newsletter" description="Subscribe to the JM Recipes Web newsletter for weekly recipes, tips, and freebies.">
  <Header slot="header-override" />

  <div class="max-w-2xl mx-auto text-center py-12">
    <!-- Icon -->
    <div class="w-20 h-20 bg-honey rounded-full flex items-center justify-center mx-auto mb-6 shadow-md">
      <svg class="w-10 h-10 text-bark" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>

    <h1 class="font-serif text-4xl text-bark font-bold mb-3">
      Join <span class="text-honey">200,000+</span> Subscribers
    </h1>
    <p class="text-muted text-lg mb-10 leading-relaxed">
      Get our best recipes, tips, and kitchen hacks delivered straight to your inbox. No fuss, no fluff — just great food.
    </p>

    <!-- Form -->
    <form class="flex flex-col sm:flex-row gap-3 mb-10" onsubmit="return false;">
      <input
        id="newsletter-first-name"
        name="firstName"
        type="text"
        placeholder="First name"
        aria-label="First name"
        class="flex-1 px-5 py-3 rounded-full border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-honey text-sm"
      />
      <input
        id="newsletter-email"
        name="email"
        type="email"
        placeholder="your@email.com"
        aria-label="Email address"
        class="flex-1 px-5 py-3 rounded-full border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-honey text-sm"
        required
      />
      <button type="submit" class="btn-primary px-8 py-3 whitespace-nowrap">
        Subscribe Free →
      </button>
    </form>

    <!-- Benefits -->
    <ul class="text-left inline-block space-y-3">
      {benefits.map((b) => (
        <li class="text-gray-600 text-sm flex items-start gap-2">
          <span class="shrink-0">{b.charAt(0)}</span>
          <span>{b.slice(2)}</span>
        </li>
      ))}
    </ul>
  </div>

  <Footer slot="footer" />
</Layout>
