---
// src/pages/newsletter.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const benefits = [
  "New recipes every week, delivered to your inbox",
  "Free meal plans and grocery list templates",
  "Exclusive tips for healthy, simple cooking",
  "Early access to new cookbooks and resources",
  "No spam, ever. Unsubscribe anytime.",
];
---

<Layout
  title="Newsletter"
  description="Subscribe to the JM Recipes Web newsletter for weekly recipes, tips, and freebies."
>
  <Header slot="header-override" />

  <div class="max-w-2xl mx-auto text-center py-12">
    <!-- Icon -->
    <div
      class="w-20 h-20 bg-honey rounded-full flex items-center justify-center mx-auto mb-6 shadow-md"
    >
      <svg
        class="w-10 h-10 text-bark"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path>
      </svg>
    </div>

    <h1 class="font-serif text-4xl text-bark font-bold mb-3">
      Join <span class="text-honey">200,000+</span> Subscribers
    </h1>
    <p class="text-muted text-lg mb-10 leading-relaxed">
      Get our best recipes, tips, and kitchen hacks delivered straight to your
      inbox. No fuss, no fluff — just great food.
    </p>

    <!-- Form -->
    <form
      class="flex flex-col sm:flex-row gap-3 mb-10"
      onsubmit="return false;"
    >
      <input
        id="newsletter-first-name"
        name="firstName"
        type="text"
        placeholder="First name"
        aria-label="First name"
        class="flex-1 px-5 py-3 rounded-full border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-honey text-sm"
        required
      />
      <input
        id="newsletter-email"
        name="email"
        type="email"
        placeholder="your@email.com"
        aria-label="Email address"
        class="flex-1 px-5 py-3 rounded-full border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-honey text-sm"
        required
      />
      <button
        type="submit"
        class="whitespace-nowrap inline-flex items-center gap-2 bg-honey text-bark font-bold text-base px-10 py-4 rounded-full shadow-lg hover:bg-amber-400 hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all duration-200 tracking-wide"
      >
        Subscribe Free
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </button>
    </form>

    <!-- Benefits -->
    <ul class="text-left inline-block space-y-3">
      {
        benefits.map((b) => (
          <li class="text-bark text-sm flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 mt-0.5 shrink-0 text-honey"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            <span>{b}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <Footer slot="footer" />
</Layout>
