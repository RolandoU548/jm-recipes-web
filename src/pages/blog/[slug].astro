---
// src/pages/blog/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdBanner from '../../components/AdBanner.astro';
import PortableTextRenderer from '../../components/PortableTextRenderer';
import { getAllPostSlugs, getPostBySlug, toYouTubeEmbedUrl } from '../../lib/fetchData';
import { urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const imgSrc = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).auto('format').url()
  : null;

const datePublished = post._createdAt
  ? new Date(post._createdAt).toISOString()
  : new Date().toISOString();

const dateFormatted = post._createdAt
  ? new Date(post._createdAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const embedUrl = toYouTubeEmbedUrl(post.videoUrl ?? '');

// ── JSON-LD BlogPosting Schema ────────────────────────────────────────────────
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt ?? `Read ${post.title} on the JM Recipes Web blog.`,
  image: imgSrc ? [imgSrc] : [],
  datePublished,
  dateModified: post._updatedAt ?? datePublished,
  author: {
    '@type': 'Organization',
    name: 'JM Recipes Web',
    url: 'https://jmrecipesweb.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'JM Recipes Web',
    logo: {
      '@type': 'ImageObject',
      url: 'https://jmrecipesweb.com/logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://jmrecipesweb.com/blog/${slug}`,
  },
  keywords: post.tags?.join(', ') ?? '',
};
---

<Layout
  title={post.title}
  description={post.excerpt ?? `Read ${post.title} on the JM Recipes Web blog.`}
  image={imgSrc ?? undefined}
>
  <!-- JSON-LD -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Header slot="header-override" />

  <!-- Breadcrumb -->
  <nav class="text-sm text-muted mb-6 flex items-center gap-2" aria-label="Breadcrumb">
    <a href="/" class="hover:text-honey transition-colors">Home</a>
    <span aria-hidden="true">›</span>
    <a href="/blog" class="hover:text-honey transition-colors">Blog</a>
    <span aria-hidden="true">›</span>
    <span class="text-bark font-medium truncate">{post.title}</span>
  </nav>

  <!-- Title -->
  <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-bark font-bold mb-4 leading-tight text-balance">
    {post.title}
  </h1>

  <!-- Date & Tags row -->
  <div class="flex flex-wrap items-center gap-4 mb-6">
    {dateFormatted && (
      <time datetime={datePublished} class="text-sm text-muted">
        {dateFormatted}
      </time>
    )}
    {post.tags && post.tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {post.tags.map((tag: string) => <span class="tag-pill">{tag}</span>)}
      </div>
    )}
  </div>

  <!-- Hero: Video (priority) or Image (fallback) -->
  {embedUrl ? (
    <div class="aspect-video w-full rounded-2xl overflow-hidden mb-8 shadow-md bg-gray-900">
      <iframe
        src={embedUrl}
        title={`${post.title} — video`}
        class="w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />
    </div>
  ) : imgSrc && (
    <div class="relative w-full aspect-[16/9] rounded-2xl overflow-hidden mb-8 shadow-md">
      <img
        src={imgSrc}
        alt={post.title}
        transition:name={`blog-image-${post.slug.current}`}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
  )}

  <!-- House Ad (above content) -->
  <div class="mb-8">
    <AdBanner type="house" />
  </div>

  <!-- Post Body -->
  <article class="prose prose-bark max-w-none mb-10">
    <PortableTextRenderer client:load value={post.body ?? []} />
  </article>

  <!-- AdSense (below content) -->
  <div class="mb-10">
    <AdBanner type="adsense" />
  </div>

  <Footer slot="footer" />
</Layout>
