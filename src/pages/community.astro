---
// src/pages/community.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Community"
  description="Join our vibrant community of food lovers, home cooks, and wellness enthusiasts."
>
  <Header slot="header-override" />

  <div class="mb-10">
    <h1 class="font-serif text-4xl text-bark font-bold mb-3">
      Our Community 🌿
    </h1>
    <p class="text-muted text-lg max-w-2xl">
      A warm, welcoming space for people who believe that nourishing food can
      also be simple, affordable, and delicious.
    </p>
  </div>

  <!-- Feature cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
    {
      [
        {
          emoji: "💬",
          title: "Discussion Forums",
          desc: "Share your recipe recreations, ask questions, and connect with thousands of fellow home cooks.",
        },
        {
          emoji: "📸",
          title: "Recipe Gallery",
          desc: "Upload your beautiful food photos and get inspired by what our community is cooking this week.",
        },
        {
          emoji: "🎉",
          title: "Monthly Challenges",
          desc: "Join our themed cooking challenges each month for a chance to win exclusive prizes and features.",
        },
      ].map(({ emoji, title, desc }) => (
        <div class="card p-6 text-center hover:-translate-y-1 transition-transform duration-200">
          <div class="text-4xl mb-4">{emoji}</div>
          <h2 class="font-serif text-xl text-bark font-semibold mb-2">
            {title}
          </h2>
          <p class="text-muted text-sm leading-relaxed">{desc}</p>
        </div>
      ))
    }
  </div>

  <!-- Lorem sections -->
  <section class="prose max-w-none mb-10">
    <h2 class="font-serif text-2xl text-bark mb-3">Why Join Us?</h2>
    <p class="text-muted leading-relaxed mb-4">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
      tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
      veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea
      commodo consequat. Duis aute irure dolor in reprehenderit in voluptate
      velit esse cillum dolore eu fugiat nulla pariatur.
    </p>
    <p class="text-muted leading-relaxed">
      Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia
      deserunt mollit anim id est laborum. Sed ut perspiciatis unde omnis iste
      natus error sit voluptatem accusantium doloremque laudantium, totam rem
      aperiam, eaque ipsa quae ab illo inventore veritatis.
    </p>
  </section>

  <!-- CTA -->
  <div
    class="relative overflow-hidden rounded-3xl p-10 text-center shadow-xl"
    style="background: linear-gradient(135deg, #FFC857 0%, #f5a623 100%);"
  >
    <!-- Decorative rings -->
    <div
      class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-white/10 pointer-events-none"
    >
    </div>
    <div
      class="absolute -bottom-14 -left-14 w-64 h-64 rounded-full bg-white/10 pointer-events-none"
    >
    </div>

    <div class="relative">
      <p
        class="text-bark/70 font-semibold text-xs uppercase tracking-widest mb-2"
      >
        Free to join
      </p>
      <h2
        class="font-serif text-3xl md:text-4xl text-bark font-bold mb-3 leading-tight"
      >
        Ready to join the kitchen table?
      </h2>
      <p class="text-bark/70 text-base mb-7 max-w-md mx-auto">
        A free, welcoming space filled with people who love simple, nourishing
        food — just like you.
      </p>
      <a
        href="/newsletter"
        class="inline-flex items-center gap-2 bg-bark text-cream font-bold text-base px-10 py-4 rounded-full shadow-lg hover:bg-bark/90 hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all duration-200 tracking-wide"
      >
        Join the Community
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
