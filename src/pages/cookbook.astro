---
// src/pages/cookbook.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Cookbook — Coming Soon" description="Our most-anticipated cookbook is almost here. Sign up for early-bird access and exclusive updates.">
  <Header slot="header-override" />

  <div class="max-w-3xl mx-auto">

    <!-- Hero section -->
    <div class="relative rounded-3xl overflow-hidden bg-gradient-to-br from-bark via-bark/80 to-honey/50 mb-10 shadow-xl">
      <!-- Book image placeholder -->
      <div class="flex flex-col md:flex-row items-center gap-8 p-8 md:p-12">

        <!-- Book cover placeholder -->
        <div class="shrink-0 w-48 h-64 bg-white/10 border-2 border-white/20 rounded-2xl flex flex-col items-center justify-center shadow-2xl">
          <svg class="w-16 h-16 text-honey/60 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          <span class="text-white/40 text-xs font-mono">COMING 2025</span>
        </div>

        <!-- Text block -->
        <div class="text-white text-center md:text-left">
          <span class="inline-block bg-honey text-bark text-xs font-bold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">
            🎉 Coming Soon
          </span>
          <h1 class="font-serif text-3xl md:text-5xl font-bold leading-tight mb-3">
            The JM Recipes Web Cookbook
          </h1>
          <p class="text-white/70 text-lg leading-relaxed mb-4">
            100 simple, plant-forward recipes that prove you don't need a culinary degree to eat beautifully. Every recipe uses 10 ingredients or less.
          </p>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start text-sm text-white/60">
            <span>📖 256 pages</span>
            <span>·</span>
            <span>🥘 100 recipes</span>
            <span>·</span>
            <span>📸 Full-colour photography</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Countdown placeholder -->
    <div class="text-center mb-10">
      <p class="text-muted text-sm uppercase tracking-widest mb-4">Early Access Launches In</p>
      <div class="flex items-center justify-center gap-4">
        {[['00', 'Days'], ['00', 'Hours'], ['00', 'Mins'], ['00', 'Secs']].map(([val, label]) => (
          <div class="flex flex-col items-center bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-4 min-w-[70px]">
            <span class="font-serif text-3xl font-bold text-bark">{val}</span>
            <span class="text-xs text-muted uppercase tracking-wider mt-1">{label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Sign-up form -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center">
      <h2 class="font-serif text-2xl text-bark font-bold mb-2">Be First in Line 🍯</h2>
      <p class="text-muted mb-6">Get early-bird pricing, exclusive bonus recipes, and launch-day updates before anyone else.</p>
      <form class="flex flex-col sm:flex-row gap-3" onsubmit="return false;">
        <input
          type="email"
          placeholder="your@email.com"
          aria-label="Email address for cookbook updates"
          class="flex-1 px-5 py-3 rounded-full border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-honey text-sm"
          required
        />
        <button type="submit" class="btn-primary px-8 py-3 whitespace-nowrap">
          Notify Me →
        </button>
      </form>
      <p class="text-xs text-gray-400 mt-3">No spam. Unsubscribe anytime.</p>
    </div>

  </div>

  <Footer slot="footer" />
</Layout>
